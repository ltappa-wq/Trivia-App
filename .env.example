# Supabase — project URL and keys. Get these from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose to the browser. Used by privileged server actions (KTD6/KTD7).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# xAI / Grok — question generation (KTD5/KTD10). Server-only.
XAI_API_KEY=your-xai-api-key
# Optional overrides (defaults applied in lib/generation if unset):
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4.20-0309-non-reasoning

# Sentry — error monitoring. All optional; the SDK no-ops when the DSN is unset,
# so the app runs fine without these. Get the DSN from your Sentry project.
# NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (client-side error capture);
# SENTRY_DSN (falls back to the public one) is used server-side.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@oyyyy.ingest.sentry.io/zzzzz
# SENTRY_DSN=https://xxxxx@oyyyy.ingest.sentry.io/zzzzz
# Source-map upload at build time (CI/Vercel). Without these, builds still
# succeed but stack traces stay minified. Create the token in Sentry settings.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_your-auth-token
